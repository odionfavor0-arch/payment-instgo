            <optgroup label="Tourism &amp; Travel">
              <option>Tourism - General Travel</option>
              <option>Schengen Visa Processing</option>
              <option>Airport Pickup &amp; Drop-Off</option>
              <option>Hotel &amp; Accommodation Booking</option>
              <option>Flight Booking</option>
              <option>Travel Insurance</option>
              <option>Full Logistics Package</option>
            </optgroup>
            <optgroup label="Visa Services">
              <option>Visa Assessment</option>
              <option>Digital Nomad Visa</option>
              <option>Permanent Residency</option>
              <option>Citizenship Application</option>
              <option>Relocation Pathway</option>
            </optgroup>
          </select>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>Amount Paid <span class="req">*</span></label>
            <input type="text" id="f-amount" placeholder="e.g. &#8358;500,000 or &euro;500">
          </div>
          <div class="form-group">
            <label>Payment Method <span class="req">*</span></label>
            <select id="f-method">
              <option value="">Select...</option>
              <option>Naira Bank Transfer</option>
              <option>Euro WISE Transfer</option>
              <option>Stripe Card</option>
            </select>
          </div>
        </div>
        <div class="form-group">
          <label>Payment Date <span class="req">*</span></label>
          <input type="date" id="f-date">
        </div>
        <div class="form-group">
          <label>Upload Payment Receipt <span class="req">*</span></label>
          <div class="file-wrap" id="file-wrap">
            <span class="upload-icon">&#128206;</span>
            <p id="file-label">Click to upload receipt (JPG, PNG or PDF)</p>
          </div>
          <input type="file" id="f-receipt" style="display:none;" accept="image/jpeg,image/png,image/jpg,application/pdf">
        </div>
        <div class="form-group">
          <label>Additional Notes</label>
          <textarea id="f-notes" rows="3" placeholder="Anything else we should know..."></textarea>
        </div>

        <div id="status-msg"></div>

        <button type="button" id="submit-btn" class="submit-btn">Submit Payment Confirmation</button>
        <p class="terms-note">By submitting you confirm your payment and accept InstaGo's Terms and Conditions.</p>
      </div>
    </div>
  </div>

</div><!-- /#main-content -->

<div class="success-screen" id="success-screen">
  <div class="success-icon">&#10003;</div>
  <h2>Payment Confirmation Received!</h2>
  <p>Thank you! We have received your confirmation and our team is verifying your payment now. You will hear from us within 1 to 2 hours.</p>
  <div class="success-contact">
    Questions? Reach us at<br>
    <a href="mailto:info@instagoedtravels.com">info@instagoedtravels.com</a><br>
    +372 53539474
  </div>
</div>

<div class="footer">
  <div class="footer-brand">Insta<span>Go</span></div>
  <p>
    <a href="https://instagoedtravels.com">instagoedtravels.com</a> &middot;
    info@instagoedtravels.com &middot; +372 53539474<br>
    Kadaka Tee 137, Tallinn, Estonia
  </p>
</div>

</div><!-- /.page-wrap -->

<script>
(function () {
  'use strict';

  /* ── CONFIG ── */
  var SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbw5ViZQ-dooXqf-3QyuJGwUNVzJSOIiy-8ner1fU4I8sMPNKoeExcx3TozTHxGoOKY/exec';

  /* ── HELPERS ── */
  function $(id) { return document.getElementById(id); }

  function showStatus(msg, type) {
    var el = $('status-msg');
    el.innerHTML = msg;
    el.style.display = 'block';
    if (type === 'error')   { el.style.cssText = 'display:block;padding:14px 16px;border-radius:10px;font-size:14px;font-weight:600;margin-bottom:14px;text-align:center;line-height:1.5;background:#fef2f2;color:#dc2626;border:1px solid #fca5a5;'; }
    if (type === 'loading') { el.style.cssText = 'display:block;padding:14px 16px;border-radius:10px;font-size:14px;font-weight:600;margin-bottom:14px;text-align:center;line-height:1.5;background:#eff6ff;color:#1d4ed8;border:1px solid #93c5fd;'; }
  }

  function showSuccess() {
    $('main-content').style.display = 'none';
    $('success-screen').style.display = 'block';
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  /* ── COPY BUTTONS ── */
  function doCopy(text, btn, label) {
    var done = function () {
      btn.innerHTML = '&#10003; Copied!';
      btn.style.background = '#10b981';
      setTimeout(function () {
        btn.innerHTML = '&#128203; ' + label;
        btn.style.background = '#004aad';
      }, 2500);
    };
    if (navigator.clipboard && window.isSecureContext) {
      navigator.clipboard.writeText(text).then(done).catch(function () { fallback(text, done); });
    } else {
      fallback(text, done);
    }
  }

  function fallback(text, done) {
    var t = document.createElement('textarea');
    t.value = text;
    t.style.cssText = 'position:fixed;left:-9999px;opacity:0;';
    document.body.appendChild(t);
    t.focus(); t.select();
    try { document.execCommand('copy') ? done() : alert('Copy manually:\n' + text); }
    catch (e) { alert('Copy manually:\n' + text); }
    document.body.removeChild(t);
  }

  $('copy-acct').addEventListener('click', function () { doCopy('9160219459', this, 'Copy Account Number'); });
  $('copy-iban').addEventListener('click', function () { doCopy('BE14967418217583', this, 'Copy IBAN'); });

  /* ── FILE UPLOAD ── */
  $('file-wrap').addEventListener('click', function () { $('f-receipt').click(); });
  $('f-receipt').addEventListener('change', function () {
    if (this.files && this.files[0]) {
      $('file-label').textContent = '\u2713 ' + this.files[0].name;
      $('file-label').style.cssText = 'color:#004aad;font-weight:700;margin:0;';
      $('file-wrap').style.borderColor = '#004aad';
      $('file-wrap').style.background  = '#f0f5ff';
      $('file-wrap').classList.remove('err');
    }
  });

  /* ── SUBMIT ── */
  $('submit-btn').addEventListener('click', function () {
    var btn = this;

    /* clear errors */
    ['f-name','f-email','f-phone','f-service','f-amount','f-method','f-date'].forEach(function (id) {
      $(id).classList.remove('err');
    });
    $('file-wrap').classList.remove('err');
    $('status-msg').style.display = 'none';

    /* read */
    var name    = $('f-name').value.trim();
    var email   = $('f-email').value.trim();
    var phone   = $('f-phone').value.trim();
    var service = $('f-service').value;
    var amount  = $('f-amount').value.trim();
    var method  = $('f-method').value;
    var date    = $('f-date').value;
    var receipt = $('f-receipt').files[0];

    /* validate */
    var bad = [];
    if (!name)    { bad.push('Full Name');      $('f-name').classList.add('err'); }
    if (!email)   { bad.push('Email');          $('f-email').classList.add('err'); }
    if (!phone)   { bad.push('Phone');          $('f-phone').classList.add('err'); }
    if (!service) { bad.push('Service Type');   $('f-service').classList.add('err'); }
    if (!amount)  { bad.push('Amount Paid');    $('f-amount').classList.add('err'); }
    if (!method)  { bad.push('Payment Method'); $('f-method').classList.add('err'); }
    if (!date)    { bad.push('Payment Date');   $('f-date').classList.add('err'); }
    if (!receipt) { bad.push('Receipt Upload'); $('file-wrap').classList.add('err'); }

    if (bad.length) {
      showStatus('&#9888;&#65039; Please complete: ' + bad.join(', '), 'error');
      return;
    }

    btn.disabled = true;
    btn.textContent = 'Submitting\u2026 please wait';
    showStatus('&#9203; Sending your details to our team\u2026', 'loading');

    /* payload — text fields only, no binary */
    var data = JSON.stringify({
      submittedAt: new Date().toLocaleString('en-GB'),
      name:        name,
      email:       email,
      phone:       phone,
      invoice:     $('f-invoice').value.trim(),
      service:     service,
      amount:      amount,
      method:      method,
      date:        date,
      notes:       $('f-notes').value.trim(),
      receiptFile: receipt.name
    });

    /* send — no-cors POST */
    fetch(SCRIPT_URL, {
      method:  'POST',
      mode:    'no-cors',
      headers: { 'Content-Type': 'text/plain' },
      body:    data
    })
    .then(function () {
      showSuccess();
    })
    .catch(function () {
      /* last-resort XHR fallback */
      var x = new XMLHttpRequest();
      x.open('POST', SCRIPT_URL, true);
      x.setRequestHeader('Content-Type', 'text/plain');
      x.onreadystatechange = function () {
        if (x.readyState === 4) { showSuccess(); }
      };
      x.onerror = function () {
        showStatus('&#10060; Network error. Please email your receipt to <a href="mailto:info@instagoedtravels.com" style="color:#dc2626;">info@instagoedtravels.com</a> or WhatsApp <strong>+372 53539474</strong>.', 'error');
        btn.disabled = false;
        btn.textContent = 'Submit Payment Confirmation';
      };
      x.send(data);
    });
  });

})();
</script>
