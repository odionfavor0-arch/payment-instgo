  <!-- STEP 2 -->
  <div class="form-section">
    <div class="section-label">
      <div class="step-badge purple">2</div>
      <h2>Confirm Your Payment</h2>
    </div>
    <div class="form-card">
      <p class="form-intro">After making your payment, fill in the details below and upload your receipt. Our team will verify and confirm within 1 to 2 hours.</p>

      <div id="pay-form">
        <div class="form-row">
