<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Complete Your Payment — InstaGo Ed-Travels</title>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;900&family=Lato:wght@300;400;700&display=swap" rel="stylesheet">
<style>
:root{--blue:#004aad;--blue-dark:#003380;--blue-deep:#001f4d;--purple:#ca6ce5;--purple-dark:#a84ec7;--success:#10b981;--border:#e2e8f0;--off-white:#f7f9ff;--text-dark:#0a1628;--text-mid:#4a5568;--text-light:#718096;}
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:'Lato',sans-serif;background:var(--off-white);color:var(--text-dark);line-height:1.6;}
.page-wrap{max-width:680px;margin:0 auto;background:#fff;min-height:100vh;box-shadow:0 0 60px rgba(0,74,173,.12);}
.header{background:linear-gradient(135deg,#001f4d 0%,#004aad 60%,#1a6dd4 100%);position:relative;overflow:hidden;}
.header::before{content:'';position:absolute;top:-60px;right:-60px;width:220px;height:220px;border-radius:50%;background:#ca6ce5;opacity:.15;}
.header::after{content:'';position:absolute;bottom:-40px;left:-40px;width:160px;height:160px;border-radius:50%;background:#ca6ce5;opacity:.1;}
.header-inner{position:relative;z-index:2;padding:36px 28px 32px;text-align:center;}
.logo-wrap{display:flex;align-items:center;justify-content:center;gap:12px;margin-bottom:20px;}
.logo-name{font-family:'Montserrat',sans-serif;font-size:22px;font-weight:900;color:#fff;letter-spacing:-.5px;line-height:1;}
.logo-name span{color:#ca6ce5;}
.logo-sub{font-size:9px;color:rgba(255,255,255,.5);letter-spacing:2.5px;text-transform:uppercase;margin-top:3px;display:block;}
.header h1{font-family:'Montserrat',sans-serif;font-size:24px;font-weight:900;color:#fff;margin-bottom:8px;}
.header p{font-size:14px;color:rgba(255,255,255,.7);max-width:360px;margin:0 auto;}
.step-pills{display:flex;justify-content:center;gap:10px;margin-top:20px;flex-wrap:wrap;}
.step-pill{background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.2);border-radius:20px;padding:6px 16px;font-family:'Montserrat',sans-serif;font-size:11px;font-weight:700;color:rgba(255,255,255,.7);}
.step-pill.active{background:#ca6ce5;border-color:#ca6ce5;color:#fff;}
.accent-rule{height:4px;background:linear-gradient(90deg,#004aad,#ca6ce5,#004aad);}
.section{padding:28px;}
.form-section{padding:28px;background:var(--off-white);}
.section-label{display:flex;align-items:center;gap:10px;margin-bottom:20px;}
.step-badge{width:30px;height:30px;border-radius:50%;background:var(--blue);color:#fff;font-family:'Montserrat',sans-serif;font-size:13px;font-weight:800;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.step-badge.purple{background:var(--purple);}
.section-label h2{font-family:'Montserrat',sans-serif;font-size:15px;font-weight:800;color:var(--text-dark);text-transform:uppercase;letter-spacing:.5px;}
.payment-card{border:1.5px solid var(--border);border-radius:14px;overflow:hidden;margin-bottom:14px;}
.pcard-head{padding:13px 18px;display:flex;align-items:center;gap:10px;}
.pcard-head.naira{background:linear-gradient(90deg,#001f4d,#004aad);}
.pcard-head.euro{background:linear-gradient(90deg,#1a3a6e,#2251aa);}
.pcard-head.card{background:linear-gradient(90deg,#5b21b6,#a84ec7);}
.pcard-head h3{font-family:'Montserrat',sans-serif;font-size:13px;font-weight:800;color:#fff;text-transform:uppercase;letter-spacing:.5px;}
.flag{font-size:18px;}
.pcard-body{padding:16px 18px;background:var(--off-white);}
.drow{display:flex;align-items:flex-start;padding:6px 0;border-bottom:1px solid var(--border);font-size:14px;}
.drow:last-of-type{border-bottom:none;}
.dlabel{width:125px;flex-shrink:0;color:var(--text-light);font-size:13px;}
.dvalue{color:var(--text-dark);font-weight:600;flex:1;}
.copy-btn{display:inline-flex;align-items:center;gap:6px;background:#004aad;color:#fff;border:none;padding:9px 16px;border-radius:8px;cursor:pointer;font-family:'Montserrat',sans-serif;font-size:12px;font-weight:700;margin-top:12px;transition:background .2s;}
.copy-btn:hover{background:#003380;}
.or-divider{display:flex;align-items:center;gap:10px;margin:6px 0;color:var(--text-light);font-size:13px;font-weight:600;}
.or-divider::before,.or-divider::after{content:'';flex:1;height:1px;background:var(--border);}
.stripe-btn{display:flex;align-items:center;justify-content:center;gap:8px;background:linear-gradient(135deg,#5b21b6,#ca6ce5);color:#fff;padding:14px 24px;border-radius:10px;text-decoration:none;font-family:'Montserrat',sans-serif;font-weight:800;font-size:14px;transition:opacity .2s;}
.stripe-btn:hover{opacity:.9;}
.stripe-note{font-size:12px;color:var(--text-light);text-align:center;margin-top:8px;}
.narration-note{background:#fff8e6;border-left:3px solid #f59e0b;border-radius:0 8px 8px 0;padding:12px 14px;font-size:13px;color:#92400e;margin-top:14px;line-height:1.6;}
.form-card{background:#fff;border-radius:16px;padding:24px;box-shadow:0 2px 20px rgba(0,74,173,.07);}
.form-intro{font-size:14px;color:var(--text-mid);margin-bottom:22px;line-height:1.7;}
.form-group{margin-bottom:18px;}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:14px;}
label{display:block;margin-bottom:6px;font-weight:700;font-size:13px;color:var(--text-dark);}
.req{color:#ca6ce5;}
input,select,textarea{width:100%;padding:11px 13px;border:1.5px solid var(--border);border-radius:8px;font-size:14px;font-family:'Lato',sans-serif;color:var(--text-dark);background:#fff;transition:border-color .2s,box-shadow .2s;-webkit-appearance:none;appearance:none;}
input:focus,select:focus,textarea:focus{outline:none;border-color:#004aad;box-shadow:0 0 0 3px rgba(0,74,173,.1);}
input.err,select.err{border-color:#ef4444!important;}
.file-wrap{border:2px dashed var(--border);border-radius:8px;padding:20px;text-align:center;cursor:pointer;transition:border-color .2s,background .2s;background:#fff;}
.file-wrap:hover{border-color:#004aad;background:#f0f5ff;}
.file-wrap.err{border-color:#ef4444!important;}
.upload-icon{font-size:28px;margin-bottom:6px;display:block;}
.file-wrap p{font-size:13px;color:var(--text-light);margin:0;}
.submit-btn{width:100%;background:linear-gradient(135deg,#a84ec7,#ca6ce5);color:#fff;border:none;padding:16px;border-radius:10px;font-family:'Montserrat',sans-serif;font-size:15px;font-weight:800;cursor:pointer;letter-spacing:.5px;box-shadow:0 4px 20px rgba(202,108,229,.4);transition:opacity .2s;margin-top:4px;}
.submit-btn:hover{opacity:.9;}
.submit-btn:disabled{opacity:.5;cursor:not-allowed;}
.terms-note{font-size:12px;color:var(--text-light);text-align:center;margin-top:10px;line-height:1.6;}
#status-msg{display:none;padding:14px 16px;border-radius:10px;font-size:14px;font-weight:600;margin-bottom:14px;text-align:center;line-height:1.5;}
.success-screen{display:none;padding:48px 28px;text-align:center;}
.success-icon{width:70px;height:70px;border-radius:50%;background:linear-gradient(135deg,#004aad,#ca6ce5);display:flex;align-items:center;justify-content:center;margin:0 auto 22px;font-size:36px;color:#fff;font-weight:900;}
.success-screen h2{font-family:'Montserrat',sans-serif;font-size:22px;font-weight:900;color:var(--text-dark);margin-bottom:12px;}
.success-screen p{font-size:15px;color:var(--text-mid);line-height:1.8;max-width:380px;margin:0 auto 20px;}
.success-contact{background:var(--off-white);border-radius:12px;padding:18px 24px;font-size:14px;color:var(--text-mid);line-height:1.9;display:inline-block;}
.success-contact a{color:#004aad;text-decoration:none;font-weight:700;}
.footer{background:#001f4d;padding:22px 28px;text-align:center;}
.footer-brand{font-family:'Montserrat',sans-serif;font-size:16px;font-weight:900;color:#fff;margin-bottom:6px;}
.footer-brand span{color:#ca6ce5;}
.footer p{font-size:12px;color:rgba(255,255,255,.4);line-height:1.9;}
.footer a{color:rgba(255,255,255,.6);text-decoration:none;}
@media(max-width:560px){.header-inner{padding:24px 16px;}.header h1{font-size:20px;}.section,.form-section{padding:20px 14px;}.form-card{padding:18px 14px;}.form-row{grid-template-columns:1fr;}.dlabel{width:100px;}}
</style>
</head>
<body>
<div class="page-wrap">

<div class="header">
  <div class="header-inner">
    <div class="logo-wrap">
      <svg width="56" height="56" viewBox="0 0 56 56" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M28 50 C28 50 4 35 4 20 C4 12 10 6 18 6 C22.5 6 26.5 8.5 28 13 C29.5 8.5 33.5 6 38 6 C46 6 52 12 52 20 C52 35 28 50 28 50Z" fill="#ca6ce5"/>
        <path d="M16 24 L30 29 L16 34 V30 L24 29 L16 26 V24Z" fill="#004aad"/>
        <path d="M30 29 L40 25 L41 29 L40 33 L30 29Z" fill="#004aad" opacity="0.8"/>
        <path d="M26 33 L30 31.5 L34 33 L30 38Z" fill="#004aad" opacity="0.6"/>
      </svg>
      <div>
        <div class="logo-name">Insta<span>Go</span></div>
        <span class="logo-sub">Ed-Travels &amp; Tours</span>
      </div>
    </div>
    <h1>Complete Your Payment</h1>
    <p>Follow the two steps below to secure your booking and get started.</p>
    <div class="step-pills">
      <div class="step-pill active">Step 1 &mdash; Make Payment</div>
      <div class="step-pill active">Step 2 &mdash; Confirm Below</div>
    </div>
  </div>
</div>
<div class="accent-rule"></div>

<div id="main-content">

  <!-- STEP 1 -->
  <div class="section">
    <div class="section-label">
      <div class="step-badge">1</div>
      <h2>Make Your Payment</h2>
    </div>

    <div class="payment-card">
      <div class="pcard-head naira">
        <span class="flag">&#127475;&#127468;</span>
        <h3>Nigerian Naira Transfer</h3>
      </div>
      <div class="pcard-body">
        <div class="drow"><span class="dlabel">Bank</span><span class="dvalue">Moniepoint Microfinance Bank</span></div>
        <div class="drow"><span class="dlabel">Account Name</span><span class="dvalue">InstaGo Ed Travels</span></div>
        <div class="drow"><span class="dlabel">Account No.</span><span class="dvalue">9160219459</span></div>
        <div class="drow"><span class="dlabel">Exchange Rate</span><span class="dvalue">&#8358;1,750 = &euro;1 (subject to change)</span></div>
        <button class="copy-btn" id="copy-acct">&#128203; Copy Account Number</button>
      </div>
    </div>

    <div class="or-divider">OR</div>

    <div class="payment-card">
      <div class="pcard-head euro">
        <span class="flag">&#127466;&#127482;</span>
        <h3>Euro Bank Transfer (WISE)</h3>
      </div>
      <div class="pcard-body">
        <div class="drow"><span class="dlabel">Account Name</span><span class="dvalue">INSTAGO ED TRAVEL &amp; TOURS O&Uuml;</span></div>
        <div class="drow"><span class="dlabel">IBAN</span><span class="dvalue">BE14 9674 1821 7583</span></div>
        <div class="drow"><span class="dlabel">BIC</span><span class="dvalue">TRWIBEB1XXX</span></div>
        <div class="drow"><span class="dlabel">Address</span><span class="dvalue">Rue du Tr&ocirc;ne 100, 3rd Floor, 1050 Brussels, Belgium</span></div>
        <button class="copy-btn" id="copy-iban">&#128203; Copy IBAN</button>
      </div>
    </div>

    <div class="or-divider">OR</div>

    <div class="payment-card">
      <div class="pcard-head card">
        <span class="flag">&#128179;</span>
        <h3>Pay by Card (International)</h3>
      </div>
      <div class="pcard-body">
        <p style="font-size:14px;color:#4a5568;margin-bottom:14px;">Pay securely online using any debit or credit card.</p>
        <a href="https://buy.stripe.com/fZe9Bm2eB0JE3a87sE" class="stripe-btn" target="_blank">&#128274; Pay Securely with Card &rarr;</a>
        <p class="stripe-note">Secured by Stripe &middot; 256-bit encryption</p>
